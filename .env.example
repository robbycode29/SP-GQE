# Copy to .env and adjust. Never commit .env with real secrets.

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=dissertation2026

# Ollama (default local)
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_LLM=mistral
OLLAMA_EMBED=nomic-embed-text

# Groq — optional; if GROQ_API_KEY is set, plan stack uses Groq for generation (MiniLM embeddings)
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.1-8b-instant
#
# Free-plan limits for llama-3.1-8b-instant (adjust if you change model — see Groq console):
#   RPM 30, RPD 14.4K, TPM 6K, TPD 500K
# GROQ_MAX_REQUESTS_PER_MINUTE=30
# GROQ_MAX_TOKENS_PER_MINUTE=6000
# GROQ_MAX_REQUESTS_PER_DAY=14400
# GROQ_MAX_TOKENS_PER_DAY=500000
# Dashboard usage today (UTC day) before this repo’s run — only tokens/requests from *this* machine are in data/.groq_quota_state.json
# GROQ_TOKENS_USED_TODAY_INITIAL=0
# GROQ_REQUESTS_USED_TODAY_INITIAL=0
# GROQ_TPD_SAFETY_MARGIN=2000
#
# Or set an exact gap between chat completions (overrides RPM if set):
# GROQ_MIN_INTERVAL_SEC=2.0

# Experiment defaults (override in config/experiment.yaml)
TOP_K=5
HOTPOT_SAMPLE_SEED=42
HOTPOT_SAMPLE_SIZE=150
